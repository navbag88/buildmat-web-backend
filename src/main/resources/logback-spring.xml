<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Imports %clr and %wEx converters provided by Spring Boot -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ── Configurable log directory (set logging.file.path or LOG_DIR env var) -->
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="logs"/>

    <!-- ── Console appender (coloured, human-readable) ──────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr([%t]){faint} %clr(%-40.40logger{39}){cyan} : %m%n%wEx</pattern>
        </encoder>
    </appender>

    <!-- ── Rolling file – all levels ────────────────────────────────────────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/buildmat.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- daily roll + size cap; compressed with .gz -->
            <fileNamePattern>${LOG_PATH}/buildmat.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>300MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%t] %-40.40logger{39} : %m%n%wEx</pattern>
        </encoder>
    </appender>

    <!-- ── Rolling file – ERROR only (kept 90 days for post-mortem) ─────────── -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/buildmat-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/buildmat-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%t] %-40.40logger{39} : %m%n%wEx</pattern>
        </encoder>
    </appender>

    <!-- ── Suppress framework noise ─────────────────────────────────────────── -->
    <logger name="org.hibernate"                           level="WARN"/>
    <logger name="org.springframework"                     level="WARN"/>
    <logger name="org.springframework.security"            level="WARN"/>
    <logger name="com.zaxxer.hikari"                       level="WARN"/>
    <logger name="org.apache.poi"                          level="WARN"/>

    <!-- ── Application code: DEBUG so all our log statements appear ─────────── -->
    <logger name="com.buildmat" level="DEBUG"/>

    <!-- ── Root: INFO to catch anything we haven't explicitly set ───────────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
